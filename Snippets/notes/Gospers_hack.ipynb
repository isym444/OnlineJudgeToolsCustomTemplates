   "source": [
    "For iterating through all numbers from 1 to N with K bits set in O(C(N, K)) time complexity vs naive 2^N"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "623b5f29",
   "metadata": {},
   "outputs": [],
   "source": [
    "for (int x = (1<<K)-1; x < (1<<N); ) {\n",
    "    // use x\n",
    "    int c = x & -x, r = x + c;\n",
    "    x = (((r ^ x) >> 2) / c) | r;\n",
    "}"
   ]
  },
